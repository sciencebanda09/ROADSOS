# ROADSOS- Environment Variables
# Copy this file to .env and fill in your key

# Google Gemini API key (FREE tier)
# Get it at: https://aistudio.google.com/app/apikey
# Free limits: 15 requests/min, 1500 requests/day — no credit card needed
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: custom DB path (default: roadsos.db in project folder)
# ROADSOS_DB=/path/to/roadsos.db
